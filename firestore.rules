rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================================
    // HELPER FUNCTIONS
    // ============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isSchoolUser() {
      return isAuthenticated() && 
             request.auth.token.schoolId != null &&
             exists(/databases/$(database)/documents/schools/$(request.auth.token.schoolId));
    }
    
    function hasRole(role) {
      return isAuthenticated() && request.auth.token.role == role;
    }
    
    function isAdmin() {
      return hasRole('ADMIN') || hasRole('SUPER_ADMIN');
    }
    
    function hasPermission(perm) {
      return isAuthenticated() && 
             request.auth.token.permissions != null &&
             request.auth.token.permissions[perm] == true;
    }
    
    function getSchoolId() {
      return request.auth.token.schoolId;
    }
    
    function belongsToSchool(schoolId) {
      return isAuthenticated() && getSchoolId() == schoolId;
    }
    
    // ============================================================
    // SCHOOLS (Tenant Root)
    // ============================================================
    
    match /schools/{schoolId} {
      allow read: if true;
      allow write: if true;
      
      // Subcollections - inherit school isolation
      match /{allSubcollections=**} {
        allow read: if true;
        allow write: if true;
      }
    }
    
    // ============================================================
    // SESSIONS (Academic Years)
    // ============================================================
    
    match /sessions/{sessionId} {
      // For backward compatibility - redirect to school-based
      // DEPRECATED: Use /schools/{schoolId}/sessions instead
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // ============================================================
    // CLASSES
    // ============================================================
    
    match /classes/{classId} {
      // Legacy top-level - for backward compatibility
      // DEPRECATED: Use /schools/{schoolId}/classes instead
      allow read: if true;
      allow write: if isAuthenticated();
    }
    
    // ============================================================
    // STUDENTS
    // ============================================================
    
    match /students/{studentId} {
      // Legacy top-level - for backward compatibility
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      // New school-based structure (recommended)
      match /schools/{schoolId}/students/{sid} {
        allow read: if isSchoolUser() && belongsToSchool(schoolId);
        allow create: if isSchoolUser() && belongsToSchool(schoolId) && 
          (isAdmin() || hasPermission('STUDENT_CREATE'));
        allow update: if isSchoolUser() && belongsToSchool(schoolId) && 
          (isAdmin() || hasPermission('STUDENT_UPDATE'));
        allow delete: if false;
      }
    }
    
    // ============================================================
    // FEE TYPES (NEW STRUCTURE)
    // ============================================================
    
    match /schools/{schoolId}/feeTypes/{feeTypeId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && belongsToSchool(schoolId);
    }
    
    // ============================================================
    // FEE STRUCTURES (NEW STRUCTURE)
    // ============================================================
    
    match /schools/{schoolId}/feeStructures/{feeStructureId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && belongsToSchool(schoolId);
    }
    
    // ============================================================
    // INVOICES (NEW STRUCTURE)
    // ============================================================
    
    match /schools/{schoolId}/invoices/{invoiceId} {
      allow read: if isSchoolUser() && belongsToSchool(schoolId) &&
        (isAdmin() || hasPermission('INVOICE_VIEW') || 
         request.auth.token.studentId == resource.data.student_id ||
         request.auth.token.parentOf == resource.data.student_id);
      allow create: if isSchoolUser() && belongsToSchool(schoolId) && 
        (isAdmin() || hasPermission('INVOICE_CREATE'));
      allow update: if isSchoolUser() && belongsToSchool(schoolId) && 
        (isAdmin() || hasPermission('INVOICE_UPDATE'));
      allow delete: if false;
    }
    
    // ============================================================
    // PAYMENTS (NEW STRUCTURE)
    // ============================================================
    
    match /schools/{schoolId}/payments/{paymentId} {
      allow read: if isSchoolUser() && belongsToSchool(schoolId) &&
        (isAdmin() || hasPermission('PAYMENT_VIEW') ||
         request.auth.token.studentId == resource.data.student_id ||
         request.auth.token.parentOf == resource.data.student_id);
      allow create: if isSchoolUser() && belongsToSchool(schoolId) && 
        (isAdmin() || hasPermission('PAYMENT_CREATE'));
      allow update: if isSchoolUser() && belongsToSchool(schoolId) && isAdmin();
      allow delete: if false;
    }
    
    // ============================================================
    // AUDIT LOGS (NEW STRUCTURE)
    // ============================================================
    
    match /schools/{schoolId}/auditLogs/{logId} {
      allow read: if isSchoolUser() && belongsToSchool(schoolId) && isAdmin();
      allow create: if isSchoolUser(); // System creates
      allow update: if false;
      allow delete: if false;
    }
    
    // ============================================================
    // LEGACY TOP-LEVEL COLLECTIONS (Backward Compatibility)
    // ============================================================
    
    match /marks/{docId} { allow read, write: if isAuthenticated(); }
    match /counters/{docId} { allow read, write: if isAuthenticated(); }
    match /gradingRules/{docId} { allow read, write: if isAuthenticated(); }
    match /exams/{docId} { allow read, write: if isAuthenticated(); }
    match /schedules/{docId} { allow read, write: if isAuthenticated(); }
    match /publications/{docId} { allow read, write: if isAuthenticated(); }
    match /remarks/{docId} { allow read, write: if isAuthenticated(); }
    match /exam_attendance/{docId} { allow read, write: if isAuthenticated(); }
    match /non_subject_marks/{docId} { allow read, write: if isAuthenticated(); }
    
    // ============================================================
    // PUBLIC/CMS CONTENT (Read-only for public)
    // ============================================================
    
    match /notices/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /reports/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /admitcards/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /settings/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /events/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /achievements/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /testimonials/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /holidays/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /gallery/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /staff/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /timetables/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /fees/{docId} { 
      allow read: if true; 
      allow write: if isAuthenticated(); 
    }
    match /website_content/{docId} { allow read, write: if true; }
    
    match /inquiries/{docId} {
      allow write: if true;
      allow read: if isAuthenticated();
    }
    
    // ============================================================
    // GLOBAL FALLBACK
    // ============================================================
    
    match /{document=**} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && isAdmin();
    }
  }
}