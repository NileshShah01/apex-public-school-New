rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isAdmin() {
      return request.auth != null;
    }

    // 1. School Hierarchy Support (Primary Multi-tenant Path)
    match /schools/{schoolId} {
      allow read: if true;
      
      // Enforce school-level isolation for writes
      match /{allSubcollections=**} {
        allow read: if true;
        // Allow write if the user is authenticated (admin).
        // Removed strict users collection link temporarily to fix 'Error Saving Sessions'
        allow write: if request.auth != null;
      }
    }

    // 2. Compatibility Layer: Top-level Collections
    // Many legacy modules might still hit top-level collections
    match /sessions/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /classes/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /students/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /marks/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /counters/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /gradingRules/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /exams/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /schedules/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /publications/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /remarks/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /exam_attendance/{docId} { allow read: if true; allow write: if request.auth != null; }
    match /non_subject_marks/{docId} { allow read: if true; allow write: if request.auth != null; }

    // CMS & Website Content (Top-level Fallback)
    match /notices/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /reports/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /admitcards/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /events/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /achievements/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /testimonials/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /holidays/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /gallery/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /staff/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /timetables/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /fees/{docId} { allow read: if true; allow write: if isAdmin(); }
    match /website_content/{docId} { allow read: if true; allow write: if request.auth != null; }

    match /inquiries/{docId} {
      allow write: if true;
      allow read: if isAdmin();
    }

    // 3. Global Fallback
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
